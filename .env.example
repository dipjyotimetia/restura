# ──────────────────────────────────────────────────────────────────────────────
# Restura self-hosted — example environment file.
# Copy to `.env` and fill in real values before `docker compose up`.
#
# RUNTIME env vars are read by the Node server on startup or per-request.
# BUILD-TIME env vars (prefixed VITE_*) are baked into the SPA bundle and
# require a rebuild to change. The docker-compose default rebuilds on every
# `docker compose up --build`; for an air-gapped registry, rebuild once and
# push the image.
# ──────────────────────────────────────────────────────────────────────────────

# ─────────── Network ─────────────────────────────────────────────────────────

# Host-side port mapping. The container always listens on 3000 internally.
RESTURA_PORT=3000

# Host the Node server binds to inside the container. Leave as 0.0.0.0 to
# accept connections forwarded by Docker's port mapping.
HOST=0.0.0.0

# ─────────── Environment / Auth (REQUIRED in production) ─────────────────────

# Anything other than "development" enforces the production auth path. Leave
# unset or set to "production" for self-hosted enterprise use.
ENVIRONMENT=production

# Shared-secret Bearer token for the /api/* proxy. Send it from the SPA via
# the X-Restura-Proxy-Token header (Settings → Proxy token). Generate with:
#   openssl rand -hex 32
# REQUIRED — without this or REQUIRE_CF_ACCESS, the Worker returns 503.
WORKER_PROXY_TOKEN=

# Alternative to WORKER_PROXY_TOKEN: trust a reverse-proxy header. Set to
# "true" if you front Restura with Cloudflare Access, Pomerium, oauth2-proxy,
# or any auth gateway that injects Cf-Access-Authenticated-User-Email.
REQUIRE_CF_ACCESS=false

# DEV ONLY. Setting this to "true" with ENVIRONMENT=development bypasses
# auth + relaxes localhost SSRF. NEVER set in a deployed environment.
DEV_BYPASS_AUTH=

# ─────────── CORS ────────────────────────────────────────────────────────────

# Comma-separated allow-list. Supports `*` wildcards inside hostnames
# (e.g. `https://*.corp.example`). If unset, the Worker falls back to
# echoing the request's own Origin back (safe for single-origin deployments
# where the SPA + Worker are served from one hostname).
ALLOWED_ORIGIN=

# ─────────── SSRF policy ─────────────────────────────────────────────────────

# Set to "true" to permit RFC 1918 / link-local / CGNAT upstream targets.
# Required for enterprises that legitimately need to hit internal services
# (Jenkins, internal APIs, etc.). DOES NOT mitigate DNS-rebind — see
# docs/SELF_HOSTING.md for the threat-model caveat.
ALLOW_PRIVATE_IPS=false

# ─────────── Rate limiting ───────────────────────────────────────────────────

# Always "map" in the Node build (per-process in-memory limiter, 100 req /
# 60s). The "binding" / "binding-shadow" modes are Cloudflare-only.
RATE_LIMITER=map

# ─────────── Echo placeholder URLs (BUILD-TIME, optional) ────────────────────

# The renderer ships with example placeholder URLs pointing at the public
# echo.restura.dev. Override at BUILD TIME to point at an internal echo
# server (or just leave the placeholders broken if your users always type
# their own URLs).
#
# docker compose passes these into the build stage automatically via
# `docker compose build --build-arg`. Leave unset to keep the public defaults.
VITE_ECHO_HTTP_URL=
VITE_ECHO_GRPC_URL=
VITE_ECHO_GRAPHQL_URL=
VITE_ECHO_WS_URL=
VITE_ECHO_SSE_URL=
