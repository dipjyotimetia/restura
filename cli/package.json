{
  "name": "@restura/cli",
  "version": "0.2.4",
  "description": "Restura CLI — run API collections in CI with JUnit/HTML/JSON reporters",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "restura": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node24 --clean --tsconfig tsconfig.json",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "commander": "^12.0.0",
    "csv-parse": "^5.5.6",
    "js-yaml": "^4.1.1",
    "quickjs-emscripten": "^0.32.0",
    "undici": "^8.2.0",
    "uuid": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
