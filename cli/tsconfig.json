{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vitest/globals"],
    "outDir": "./dist",
    "rootDir": "..",
    "noEmit": false,
    "declaration": false,
    "exactOptionalPropertyTypes": false,
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["shared/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../shared/**/*.ts",
    "../src/lib/shared/file-collection-schema.ts",
    "../src/lib/shared/validations.ts",
    "../src/lib/shared/dynamicVariables.ts",
    "../src/lib/opencollection/**/*.ts",
    "../src/features/scripts/lib/scriptExecutor.ts",
    "../src/features/scripts/lib/chaiSubset.ts",
    "../src/types/index.ts"
  ],
  "exclude": ["node_modules", "dist", "fixtures", "**/*.test.ts"]
}
