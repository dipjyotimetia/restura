{
  "manifest_version": 3,
  "name": "Restura Capture",
  "version": "0.1.0",
  "description": "Capture multi-protocol browser traffic (HTTP, GraphQL, WebSocket, SSE, gRPC-web) into Restura collections.",
  "minimum_chrome_version": "116",
  "permissions": ["debugger", "sidePanel", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Restura Capture",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
