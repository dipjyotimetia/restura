{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["chrome"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
