{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vscode"],
    "noEmit": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../shared/protocol/**/*.ts",
    "../../shared/opencollection/schemas.ts",
    "../../shared/opencollection/serializer.ts",
    "../../shared/text/**/*.ts"
  ],
  "exclude": ["node_modules", "out", "**/*.test.ts"]
}
