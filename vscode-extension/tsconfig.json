{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vscode"],
    "noEmit": true,
    "exactOptionalPropertyTypes": false,
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["shared/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../shared/protocol/**/*.ts",
    "../src/lib/opencollection/schemas.ts",
    "../src/lib/opencollection/serializer.ts"
  ],
  "exclude": ["node_modules", "out", "**/*.test.ts"]
}
