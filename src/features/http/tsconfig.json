{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "rootDir": "../../..",
    "baseUrl": "../../..",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
