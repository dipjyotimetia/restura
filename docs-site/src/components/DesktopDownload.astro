---
/**
 * Home-page desktop-download band. Renders a neutral SSR default, then a tiny
 * inline script detects the visitor's OS (macOS / Windows / Linux) and swaps in
 * a direct "Download for <OS>" primary button pointing at the latest GitHub
 * release. Works without JS (falls back to the Install guide) and enhances on
 * the client. No framework — plain Astro + one inline script.
 */
const RELEASES = 'https://github.com/dipjyotimetia/restura/releases/latest';
const INSTALL = '/overview/install/';
---

<section class="desktop-download" aria-label="Download the desktop app">
  <div class="dd-copy">
    <h2 class="dd-title">Get the desktop app</h2>
    <p class="dd-sub">
      Native builds for macOS, Windows &amp; Linux — unlocking Kafka, mTLS, SOCKS proxies,
      filesystem-backed collections, and OS-keychain secrets. Auto-updates itself.
    </p>
  </div>

  <div class="dd-actions">
    <a id="dd-primary" class="dd-btn dd-primary" href={INSTALL} data-releases={RELEASES} data-install={INSTALL}>
      <svg class="dd-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"/>
      </svg>
      <span id="dd-primary-label">Download desktop app</span>
    </a>
    <div class="dd-os">
      <a href={RELEASES} data-os="mac" rel="noopener" target="_blank">macOS</a>
      <span aria-hidden="true">·</span>
      <a href={RELEASES} data-os="win" rel="noopener" target="_blank">Windows</a>
      <span aria-hidden="true">·</span>
      <a href={RELEASES} data-os="linux" rel="noopener" target="_blank">Linux</a>
      <span aria-hidden="true">·</span>
      <a href={INSTALL}>All downloads</a>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const primary = document.getElementById('dd-primary');
    const label = document.getElementById('dd-primary-label');
    if (!primary || !label) return;

    const ua = navigator.userAgent || '';
    const plat =
      (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || '';
    const hay = (plat + ' ' + ua).toLowerCase();

    let os = null;
    if (/mac|iphone|ipad|ipod/.test(hay)) os = { name: 'macOS' };
    else if (/win/.test(hay)) os = { name: 'Windows' };
    else if (/linux|x11|cros/.test(hay)) os = { name: 'Linux' };

    if (os) {
      label.textContent = 'Download for ' + os.name;
      primary.setAttribute('href', primary.dataset.releases);
      primary.setAttribute('rel', 'noopener');
      primary.setAttribute('target', '_blank');
    }
    // Unknown OS keeps the SSR default → the Install guide, which lists every build.
  })();
</script>

<style>
  .desktop-download {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem 2rem;
    margin: 2.5rem 0;
    padding: 1.5rem 1.75rem;
    border-radius: 1.25rem;
    background: var(--glass-2-bg);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border: 1px solid var(--glass-border-subtle);
    box-shadow: var(--glass-shadow);
    position: relative;
    overflow: hidden;
  }
  /* Accent wash, matching the hero's cobalt→violet language. */
  .desktop-download::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgb(var(--restura-cobalt) / 0.1), transparent 55%);
    pointer-events: none;
  }
  .dd-copy,
  .dd-actions {
    position: relative;
    z-index: 1;
  }
  .dd-copy {
    flex: 1 1 18rem;
  }
  .dd-title {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.35rem;
  }
  .dd-sub {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--sl-color-gray-3);
  }
  .dd-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .dd-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 0.7rem;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.6rem 1.15rem;
    text-decoration: none;
    transition: transform 0.18s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.18s ease;
  }
  .dd-primary {
    color: #fff;
    background: linear-gradient(135deg, rgb(var(--restura-cobalt)), rgb(var(--restura-violet)));
    border: 1px solid rgb(var(--restura-cobalt) / 0.5);
    box-shadow:
      0 8px 20px -6px rgb(var(--restura-cobalt) / 0.5),
      inset 0 1px 0 rgb(255 255 255 / 0.2);
  }
  .dd-primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 12px 28px -6px rgb(var(--restura-cobalt) / 0.6),
      inset 0 1px 0 rgb(255 255 255 / 0.25);
  }
  .dd-icon {
    flex-shrink: 0;
  }
  .dd-os {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.55rem;
    font-size: 0.82rem;
    color: var(--sl-color-gray-4, var(--sl-color-gray-3));
  }
  .dd-os a {
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s ease;
  }
  .dd-os a:hover {
    color: rgb(var(--restura-cobalt));
  }
  :root[data-theme='dark'] .dd-os a:hover {
    color: rgb(120 180 255);
  }

  @media (max-width: 30rem) {
    .desktop-download {
      padding: 1.25rem 1.15rem;
    }
    .dd-actions {
      width: 100%;
    }
    .dd-primary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
