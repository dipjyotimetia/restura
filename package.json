{
  "name": "restura",
  "version": "1.7.0",
  "private": true,
  "description": "Restura - A modern multi-protocol API client for HTTP and gRPC testing",
  "author": "dipjyotimetia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dipjyotimetia/restura.git"
  },
  "bugs": {
    "url": "https://github.com/dipjyotimetia/restura/issues"
  },
  "homepage": "https://github.com/dipjyotimetia/restura#readme",
  "main": "dist/electron/electron/main/main.js",
  "workspaces": [
    "cli",
    "extension/chrome",
    "extension/vscode"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web:docker": "cross-env VITE_IS_DOCKER_BUILD=true vite build",
    "build:server": "esbuild worker/node-entry.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist/server/index.mjs --packages=external --define:__APP_VERSION__=\"\\\"$npm_package_version\\\"\" --log-level=warning",
    "build:docker": "npm run build:web:docker && npm run build:server",
    "start": "node dist/server/index.mjs",
    "preview": "vite preview",
    "lint": "biome lint src shared electron/main worker echo echo-local cli extension/chrome extension/vscode tests scripts",
    "lint:fix": "biome check --write src shared electron/main worker echo echo-local cli extension/chrome extension/vscode tests scripts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "node scripts/ensure-sandbox-libs.mjs && tsc --noEmit",
    "type-check:tooling": "tsc --noEmit -p tsconfig.tooling.json && tsc --noEmit -p tsconfig.tooling-js.json",
    "type-check:all": "npm run type-check && npm run type-check:tooling && tsc --noEmit -p electron/tsconfig.json && tsc --noEmit -p src/features/http/tsconfig.json && tsc --noEmit -p worker/tsconfig.json && tsc --noEmit -p echo/tsconfig.json && tsc --noEmit -p echo-local/tsconfig.json && npm run --workspace cli type-check && npm run --workspace @restura/extension type-check && npm run --workspace restura-vscode type-check",
    "test": "node scripts/ensure-sandbox-libs.mjs && vitest",
    "test:run": "node scripts/ensure-sandbox-libs.mjs && vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:electron": "playwright test --config e2e-electron/playwright.config.ts",
    "test:e2e:electron:build": "npm run electron:build:web && npm run electron:compile",
    "test:contract": "vitest run tests/contract",
    "proto:gen": "buf generate",
    "gen:opencollection-types": "node scripts/gen-opencollection-types.mjs",
    "verify:opencollection-types": "npm run gen:opencollection-types && git diff --exit-code shared/opencollection/spec-types.ts",
    "capabilities:matrix": "node scripts/generate-capability-matrix.mjs",
    "capabilities:check": "node scripts/generate-capability-matrix.mjs --check",
    "architecture:check": "node scripts/check-architecture.mts",
    "skills:report": "node scripts/skill-usage-report.mjs",
    "build:sandbox-libs": "node scripts/build-sandbox-libs.mjs",
    "grpc:server": "node scripts/grpc-dev-server.mjs",
    "echo:local:build": "esbuild echo-local/cli.ts --bundle --platform=node --format=cjs --target=node24 --outfile=dist/echo-local/cli.cjs --log-level=warning",
    "echo:local": "npm run echo:local:build && node dist/echo-local/cli.cjs",
    "echo:local:certs": "npm run echo:local:build && node dist/echo-local/cli.cjs certs",
    "echo:local:collection": "npm run echo:local:build && node dist/echo-local/cli.cjs collection",
    "validate:static": "npm run type-check:all && npm run lint && npm run format:check && npm run verify:opencollection-types && npm run capabilities:check && npm run architecture:check",
    "test:workspaces": "npm run --workspace cli test && npm run --workspace restura-vscode test:unit",
    "build:workspaces": "npm run --workspace cli build && npm run --workspace @restura/extension build && npm run --workspace restura-vscode build",
    "validate:test": "npm run test:ci && npm run test:workspaces",
    "validate:build": "npm run build && npm run size && npm run build:docker && npm run build:workspaces && npm run electron:build:web && npm run electron:compile",
    "validate": "npm run validate:static && npm run validate:test && npm run validate:build",
    "size": "size-limit",
    "prepare": "husky",
    "deploy": "cross-env VITE_WORKER_URL=https://api.restura.dev vite build && wrangler deploy --config dist/web/restura/wrangler.json && wrangler pages deploy dist/web/client --project-name=restura",
    "deploy:preview": "cross-env VITE_WORKER_URL=https://api.restura.dev vite build && wrangler versions upload --config dist/web/restura/wrangler.json && wrangler pages deploy dist/web/client --project-name=restura",
    "deploy:echo": "wrangler deploy --config echo/wrangler.jsonc",
    "deploy:echo:preview": "wrangler versions upload --config echo/wrangler.jsonc",
    "docs:dev": "npm --prefix docs-site run dev",
    "docs:build": "npm --prefix docs-site run build",
    "docs:check": "npm --prefix docs-site run check",
    "deploy:docs": "npm run docs:build && wrangler pages deploy docs-site/dist --project-name=restura-docs --branch=main",
    "deploy:docs:preview": "npm run docs:build && wrangler pages deploy docs-site/dist --project-name=restura-docs",
    "electron:compile": "node scripts/clean-electron-dist.mjs && tsc -p electron/tsconfig.json && tsc-alias -p electron/tsconfig.json && node scripts/verify-electron-runtime-imports.mjs && npm run electron:bundle-preload",
    "electron:bundle-preload": "esbuild electron/main/preload.ts --bundle --platform=node --format=cjs --target=es2022 --external:electron --outfile=dist/electron/electron/main/preload.js --log-level=warning",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:compile && cross-env NODE_ENV=development electron .\"",
    "electron:build:web": "cross-env VITE_IS_ELECTRON_BUILD=true vite build",
    "electron:build:all": "npm run electron:icons && npm run electron:build:web && npm run electron:compile",
    "electron:dist": "npm run electron:build:all && electron-builder",
    "electron:dist:mac": "npm run electron:build:all && electron-builder --mac",
    "electron:dist:win": "npm run electron:build:all && electron-builder --win",
    "electron:dist:linux": "npm run electron:build:all && electron-builder --linux",
    "electron:pack": "npm run electron:build:all && electron-builder --dir",
    "electron:icons": "node scripts/generate-icons.js",
    "sentry:sourcemaps": "node scripts/sentry-sourcemaps.mjs",
    "sentry:smoke": "node scripts/sentry-smoke.mjs",
    "electron:publish": "npm run electron:build:all && npm run sentry:sourcemaps && electron-builder --publish always",
    "electron:publish:prerelease": "npm run electron:build:all && npm run sentry:sourcemaps && electron-builder --publish always --config.publish.releaseType=prerelease --config.publish.channel=beta",
    "electron:publish:mac": "npm run electron:build:all && electron-builder --mac --publish always",
    "electron:publish:win": "npm run electron:build:all && electron-builder --win --publish always",
    "electron:publish:linux": "npm run electron:build:all && electron-builder --linux --publish always",
    "version:patch": "npm version patch && git push && git push --tags",
    "version:minor": "npm version minor && git push && git push --tags",
    "version:major": "npm version major && git push && git push --tags",
    "postinstall": "electron-builder install-app-deps",
    "test:e2e:extension": "npm run build --workspace @restura/extension && playwright test --config=playwright.extension.config.ts"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@aws-crypto/sha256-js": "^5.2.0",
    "@bufbuild/protobuf": "^2.12.1",
    "@connectrpc/connect": "^2.1.2",
    "@connectrpc/connect-node": "^2.1.2",
    "@connectrpc/connect-web": "^2.1.2",
    "@dagrejs/dagre": "^3.0.0",
    "@faker-js/faker": "^10.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hono/node-server": "^2.0.8",
    "@hono/node-ws": "^1.3.1",
    "@kafkajs/confluent-schema-registry": "^4.1.0",
    "@langfuse/otel": "^5.9.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@openworkflowspec/sdk": "1.0.3-alpha4",
    "@platformatic/kafka": "2.6.1",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sentry/electron": "^7.15.0",
    "@smithy/protocol-http": "^5.5.10",
    "@smithy/signature-v4": "^5.6.4",
    "@usebruno/lang": "^0.37.1",
    "@xyflow/react": "^12.11.2",
    "ajv": "^8.20.0",
    "axios": "^1.18.1",
    "buffer": "^6.0.3",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.4.4",
    "electron-log": "^5.4.4",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "fflate": "^0.8.3",
    "framer-motion": "^12.42.2",
    "graphql": "^17.0.2",
    "graphql-ws": "^6.1.0",
    "hono": "^4.12.30",
    "js-yaml": "^5.2.1",
    "jsonc-parser": "3.3.1",
    "jsonpath-plus": "^10.4.0",
    "lucide-react": "^1.24.0",
    "monaco-editor": "^0.55.1",
    "mqtt": "^5.15.2",
    "next-themes": "^0.4.6",
    "oauth-1.0a": "^2.2.6",
    "papaparse": "^5.5.4",
    "postman-collection": "^5.3.0",
    "protobufjs": "^8.7.1",
    "quickjs-emscripten": "^0.32.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tough-cookie": "^6.0.2",
    "undici": "^8.7.0",
    "uuid": "^14.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zundo": "^2.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.7",
    "@biomejs/biome": "^2.5.3",
    "@bufbuild/protoc-gen-es": "^2.12.1",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@electron/notarize": "^3.1.1",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@grpc/reflection": "^1.0.4",
    "@playwright/test": "^1.61.1",
    "@sentry/cli": "^3.6.0",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/papaparse": "^5.5.2",
    "@types/postman-collection": "^3.5.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "better-sse": "^0.16.1",
    "chai": "^6.2.2",
    "cheerio": "^1.2.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "csv-parse": "^7.0.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^17.0.8",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "size-limit": "^12.1.0",
    "socket.io": "^4.8.3",
    "tailwindcss": "^4.3.2",
    "tsc-alias": "^1.9.1",
    "tv4": "^1.3.0",
    "typescript": "^7",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10",
    "wrangler": "^4.110.0",
    "xml2js": "^0.6.2"
  },
  "optionalDependencies": {
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3"
  },
  "overrides": {
    "graphql-ws": {
      "graphql": "$graphql"
    },
    "@hono/node-ws": {
      "@hono/node-server": "$@hono/node-server"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@12.0.1",
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "biome check --write"
    ],
    "*.{json,css}": [
      "biome format --write"
    ]
  },
  "build": {
    "extends": "./electron-builder.json"
  }
}
