{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node"]
  },
  "include": ["scripts/*.ts", "scripts/*.mts", "*.config.ts", "*.config.mts"],
  "exclude": ["node_modules", "dist", "coverage", "scripts/sandbox-shims"]
}
