# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
tmp/*

# testing
/coverage
/test-results/
/playwright-report/
/playwright/.cache/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
.env.production
.dev.vars

# typescript
*.tsbuildinfo

# vite + cloudflare
/dist/web/
.wrangler/

# electron
/dist/
/dist-electron/
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.exe
*.msi
*.blockmap
# electron-builder output yml files (like latest.yml, latest-mac.yml)
/dist/**/*.yml
/dist/**/*.yaml
!electron-builder.json

# git worktrees
.worktrees/

# Claude Code local settings (machine-specific)
.claude/settings.local.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db

# configs (legacy)
./configs/**/**
