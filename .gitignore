# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
# Workspace package deps (cli/, extension/chrome, extension/vscode) that npm
# does not hoist to the root node_modules.
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
tmp/*

# testing
/coverage
/test-results/
/playwright-report/
/playwright/.cache/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
.env.production
.dev.vars

# typescript
*.tsbuildinfo

# vite + cloudflare
/dist/web/
.wrangler/

# electron
/dist/
/dist-electron/
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.exe
*.msi
*.blockmap
# electron-builder output yml files (like latest.yml, latest-mac.yml)
/dist/**/*.yml
/dist/**/*.yaml
!electron-builder.json

# docs site (Astro Starlight)
/docs-site/node_modules/
/docs-site/dist/
/docs-site/.astro/

# git worktrees
.worktrees/

# Superpowers transient SDD reports
.superpowers/sdd/

# Claude Code local settings (machine-specific)
.claude/settings.local.json
# Claude Code transient runtime lock (session id + pid; not source)
.claude/scheduled_tasks.lock
# Claude Code skill-usage metrics (runtime data written by the measurement hook)
.claude/metrics/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db

# configs (legacy)
.claude/settings.local.json
./configs/**/**
cache/**/*
.playwright-mcp/
# Phase B — sandbox library bundle (regenerated each build by scripts/build-sandbox-libs.mjs)
shared/scripts/sandbox-libraries/bundle.generated.ts

# Extension build output
extension/chrome/dist
