{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    // DOM is included because preload.ts (compiled by this program) legitimately
    // needs it — `contextBridge`, `window`, `ipcRenderer` callbacks. The trade-off
    // is that main-only files can also reference `window`/`document` and still
    // compile; a separate preload tsconfig would split this cleanly but is
    // over-engineering for one file. Keep DOM here; rely on review for stray
    // `window` use in main-only modules.
    "lib": ["ES2022", "DOM"],
    "outDir": "../dist/electron",
    "rootDir": "..",
    "moduleResolution": "nodenext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@shared/*": ["../shared/*"],
      "@/*": ["../src/*"]
    }
  },
  "include": ["**/*.ts", "../shared/**/*.ts"],
  "exclude": ["node_modules"]
}
